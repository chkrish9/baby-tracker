generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  password     String // bcrypt hash
  name         String?
  theme        String       @default("stone")
  profilePhoto String? // relative path: users/[id]/profile/filename
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  babies       BabyParent[]
  sentInvites  Invite[]     @relation("InviteSender")
}

model Baby {
  id           String            @id @default(cuid())
  name         String
  firstName    String?
  lastName     String?
  nickname     String?
  birthDate    DateTime
  weight       Float? // kg
  height       Float? // cm
  profilePhoto String? // relative path: babies/[id]/profile/filename
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  parents      BabyParent[]
  feedings     FeedingLog[]
  diapers      DiaperLog[]
  photos       BabyPhoto[]
  documents    MedicalDocument[]
  inviteLinks  InviteBaby[]
  doctorNotes  DoctorNote[]
  appointments DoctorAppointment[]
  vaccinations   Vaccination[]
  growthRecords  GrowthRecord[]
  healthRecords  HealthRecord[]
}

model BabyParent {
  id       String     @id @default(cuid())
  userId   String
  babyId   String
  role     ParentRole @default(PARENT)
  joinedAt DateTime   @default(now())
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  baby     Baby       @relation(fields: [babyId], references: [id], onDelete: Cascade)

  @@unique([userId, babyId])
  @@index([babyId])
  @@index([userId])
}

enum ParentRole {
  OWNER
  PARENT
}

model Invite {
  id              String       @id @default(cuid())
  invitedByUserId String
  email           String
  status          InviteStatus @default(PENDING)
  token           String       @unique @default(cuid())
  expiresAt       DateTime
  createdAt       DateTime     @default(now())
  invitedBy       User         @relation("InviteSender", fields: [invitedByUserId], references: [id])
  babies          InviteBaby[]

  @@index([email])
}

model InviteBaby {
  id       String @id @default(cuid())
  inviteId String
  babyId   String
  invite   Invite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  baby     Baby   @relation(fields: [babyId], references: [id], onDelete: Cascade)

  @@unique([inviteId, babyId])
  @@index([babyId])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model FeedingLog {
  id        String      @id @default(cuid())
  babyId    String
  type      FeedingType
  amount    Float? // bottle/solid, see `unit`
  duration  Float? // breastfeeding, see `unit`
  unit      String? // "ml" | "oz" for amount, "min" | "hr" for duration
  notes     String?
  loggedAt  DateTime    @default(now())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  baby      Baby        @relation(fields: [babyId], references: [id], onDelete: Cascade)

  @@index([babyId, loggedAt(sort: Desc)])
}

enum FeedingType {
  BREAST_LEFT
  BREAST_RIGHT
  BOTTLE
  SOLID
}

model DiaperLog {
  id               String              @id @default(cuid())
  babyId           String
  type             DiaperType
  notes            String?
  loggedAt         DateTime            @default(now())
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  baby             Baby                @relation(fields: [babyId], references: [id], onDelete: Cascade)
  appointmentLinks DiaperAppointment[]

  @@index([babyId, loggedAt(sort: Desc)])
}

enum DiaperType {
  WET
  DIRTY
  BOTH
  DRY
}

model BabyPhoto {
  id               String             @id @default(cuid())
  babyId           String
  path             String // relative: babies/[id]/photos/filename
  filename         String
  size             Int
  mimeType         String
  caption          String?
  takenAt          DateTime           @default(now())
  createdAt        DateTime           @default(now())
  baby             Baby               @relation(fields: [babyId], references: [id], onDelete: Cascade)
  appointmentLinks PhotoAppointment[]

  @@index([babyId, takenAt(sort: Desc)])
}

model PhotoAppointment {
  id            String            @id @default(cuid())
  photoId       String
  appointmentId String
  createdAt     DateTime          @default(now())
  photo         BabyPhoto         @relation(fields: [photoId], references: [id], onDelete: Cascade)
  appointment   DoctorAppointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([photoId, appointmentId])
  @@index([appointmentId])
}

model DiaperAppointment {
  id            String            @id @default(cuid())
  diaperLogId   String
  appointmentId String
  createdAt     DateTime          @default(now())
  diaperLog     DiaperLog         @relation(fields: [diaperLogId], references: [id], onDelete: Cascade)
  appointment   DoctorAppointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([diaperLogId, appointmentId])
  @@index([appointmentId])
}

model DoctorNote {
  id            String             @id @default(cuid())
  babyId        String
  appointmentId String?
  question      String
  answered      Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  baby          Baby               @relation(fields: [babyId], references: [id], onDelete: Cascade)
  appointment   DoctorAppointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([babyId, createdAt(sort: Desc)])
  @@index([appointmentId])
}

model DoctorAppointment {
  id          String              @id @default(cuid())
  babyId      String
  date        DateTime
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  baby        Baby                @relation(fields: [babyId], references: [id], onDelete: Cascade)
  questions   DoctorNote[]
  photoLinks  PhotoAppointment[]
  diaperLinks DiaperAppointment[]

  @@index([babyId, date])
}

model Vaccination {
  id        String   @id @default(cuid())
  babyId    String
  name      String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  baby      Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)

  @@index([babyId, date(sort: Desc)])
}

model GrowthRecord {
  id         String     @id @default(cuid())
  babyId     String
  type       GrowthType
  value      Float
  unit       String // "kg" | "lb" for WEIGHT, "cm" | "in" for HEIGHT
  recordedAt DateTime
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  baby       Baby       @relation(fields: [babyId], references: [id], onDelete: Cascade)

  @@index([babyId, type, recordedAt(sort: Desc)])
}

enum GrowthType {
  WEIGHT
  HEIGHT
}

model HealthRecord {
  id        String   @id @default(cuid())
  babyId    String
  title     String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  baby      Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)

  @@index([babyId, date(sort: Desc)])
}

model MedicalDocument {
  id           String   @id @default(cuid())
  babyId       String
  path         String // relative: babies/[id]/documents/filename
  originalName String
  size         Int
  mimeType     String
  uploadedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  baby         Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)

  @@index([babyId, uploadedAt(sort: Desc)])
}
